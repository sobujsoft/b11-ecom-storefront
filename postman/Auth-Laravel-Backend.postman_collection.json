									"        pm.collectionVariables.set('transaction_id', json.payment.transaction_id);",
									"    }",
									"    if (json.gateway_url) {",
									"        pm.collectionVariables.set('gateway_url', json.gateway_url);",
									"    }",
									"}"
								]
							}
